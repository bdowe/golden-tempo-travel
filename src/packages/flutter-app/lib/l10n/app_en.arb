  "citiesTwo": "{first} & {second}",
  "@citiesTwo": {
    "description": "Destination summary for a trip with exactly two hub cities.",
    "placeholders": {
      "first": { "type": "String", "example": "Mexico City" },
      "second": { "type": "String", "example": "Puerto Vallarta" }
    }
  },
  "citiesMore": "{first} & {second} +{count} more",
  "@citiesMore": {
    "description": "Destination summary for a trip with more than two hub cities; count is how many are not named.",
    "placeholders": {
      "first": { "type": "String", "example": "Tokyo" },
      "second": { "type": "String", "example": "Kyoto" },
      "count": { "type": "int", "example": "2" }
    }
  }
